<Window x:Class="StickerPrintApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sticker Print Station"
        Height="820" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#FFF0F0F0"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="PageBg" Color="#FFF0F0F0"/>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="CardStroke" Color="#FFE8E8E8"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FF1A1A1A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF8C8C8C"/>
        <SolidColorBrush x:Key="TextTertiary" Color="#FFB0B0B0"/>
        <SolidColorBrush x:Key="Accent" Color="#FF6C5CE7"/>
        <SolidColorBrush x:Key="AccentBg" Color="#FFF0EEFF"/>
        <SolidColorBrush x:Key="Green" Color="#FF00B894"/>
        <SolidColorBrush x:Key="GreenBg" Color="#FFE6FAF5"/>
        <SolidColorBrush x:Key="Red" Color="#FFE17055"/>
        <SolidColorBrush x:Key="RedBg" Color="#FFFDECEA"/>
        <SolidColorBrush x:Key="Orange" Color="#FFFDCB6E"/>
        <SolidColorBrush x:Key="OrangeBg" Color="#FFFFF8E7"/>
        <SolidColorBrush x:Key="Blue" Color="#FF74B9FF"/>
        <SolidColorBrush x:Key="BlueBg" Color="#FFEEF6FF"/>
        <SolidColorBrush x:Key="InputBg" Color="#FFF8F8F8"/>
        <SolidColorBrush x:Key="InputStroke" Color="#FFE0E0E0"/>

        <!-- Card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.04" Color="Black" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stat Card -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.04" Color="Black" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon Circle -->
        <Style x:Key="IconCircle" TargetType="Border">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- TextBox -->
        <Style x:Key="DashTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource InputStroke}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="DashCombo" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <!-- Button -->
        <Style x:Key="DashBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label style -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Section Title -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <!-- Scrollable content -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28,20,28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== TOP BAR ===== -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Sticker Print Station"
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Firebase auto print for QR check-in events"
                               Foreground="{StaticResource TextSecondary}" FontSize="13"
                               FontFamily="Segoe UI Variable Text, Segoe UI" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="btnStart" Content="Start Listening"
                        Click="BtnStart_Click" Style="{StaticResource DashBtn}"
                        Background="{StaticResource Accent}" Foreground="White"
                        BorderThickness="0" Width="140" Margin="0,0,10,0"/>
                <Button Grid.Column="2" x:Name="btnStop" Content="Stop"
                        Click="BtnStop_Click" Style="{StaticResource DashBtn}"
                        Background="{StaticResource RedBg}" Foreground="{StaticResource Red}"
                        BorderBrush="{StaticResource Red}" BorderThickness="1"
                        Width="90" IsEnabled="False"/>
            </Grid>

            <!-- ===== STAT CARDS ROW ===== -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Station # -->
                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <Border Style="{StaticResource IconCircle}" Background="{StaticResource AccentBg}">
                            <TextBlock Text="&#xE772;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="{StaticResource Accent}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Station" Foreground="{StaticResource TextSecondary}"
                                   FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="12"/>
                        <TextBlock x:Name="txtStationLabel" Text="Printer #1"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <Border x:Name="statusIconBg" Style="{StaticResource IconCircle}" Background="{StaticResource RedBg}">
                            <Ellipse x:Name="statusDot" Width="14" Height="14" Fill="{StaticResource Red}"/>
                        </Border>
                        <TextBlock Text="Status" Foreground="{StaticResource TextSecondary}"
                                   FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="12"/>
                        <TextBlock x:Name="txtStatus" Text="Offline"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Jobs Printed -->
                <Border Grid.Column="4" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <Border Style="{StaticResource IconCircle}" Background="{StaticResource GreenBg}">
                            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="{StaticResource Green}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Jobs Printed" Foreground="{StaticResource TextSecondary}"
                                   FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="12"/>
                        <TextBlock x:Name="txtJobCount" Text="0"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Skipped -->
                <Border Grid.Column="6" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <Border Style="{StaticResource IconCircle}" Background="{StaticResource OrangeBg}">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="#FFE17055"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Skipped" Foreground="{StaticResource TextSecondary}"
                                   FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="12"/>
                        <TextBlock x:Name="txtSkipCount" Text="0"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== CONFIG ROW (2 cards side by side) ===== -->
            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Firebase Config -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Firebase Connection" Margin="0,0,0,14"/>
                        <TextBlock Style="{StaticResource Label}" Text="Realtime Database URL" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtFirebaseUrl" Style="{StaticResource DashTextBox}"
                                 Text="https://ace-mile-133504.firebaseio.com/" Margin="0,0,0,12"/>
                        <TextBlock Style="{StaticResource Label}" Text="Service Account Key File (optional)" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="txtKeyFile" Style="{StaticResource DashTextBox}"
                                     IsReadOnly="True" Text="" ToolTip="Select a Firebase service account JSON key file"/>
                            <Button Grid.Column="1" x:Name="btnBrowseKey" Content="&#xE838;"
                                    FontFamily="Segoe MDL2 Assets" FontSize="14"
                                    Click="BtnBrowseKey_Click" Style="{StaticResource DashBtn}"
                                    Background="{StaticResource InputBg}" Foreground="{StaticResource TextPrimary}"
                                    BorderBrush="{StaticResource InputStroke}" BorderThickness="1"
                                    Width="38" Padding="0" Margin="8,0,0,0" ToolTip="Browse key file"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Station Config -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Station Identity" Margin="0,0,0,14"/>
                        <TextBlock Style="{StaticResource Label}" Text="This machine is" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cbStationId" Style="{StaticResource DashCombo}" Margin="0,0,0,12">
                            <ComboBoxItem Content="Printer Station #1" IsSelected="True"/>
                            <ComboBoxItem Content="Printer Station #2"/>
                            <ComboBoxItem Content="Printer Station #3"/>
                        </ComboBox>
                        <TextBlock Style="{StaticResource Label}" Text="Logo image" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="txtLogoPath" Style="{StaticResource DashTextBox}"
                                     IsReadOnly="True" Text="(default embedded logo)" ToolTip="Select a logo image file"/>
                            <Button Grid.Column="1" x:Name="btnBrowseLogo" Content="&#xE838;"
                                    FontFamily="Segoe MDL2 Assets" FontSize="14"
                                    Click="BtnBrowseLogo_Click" Style="{StaticResource DashBtn}"
                                    Background="{StaticResource InputBg}" Foreground="{StaticResource TextPrimary}"
                                    BorderBrush="{StaticResource InputStroke}" BorderThickness="1"
                                    Width="38" Padding="0" Margin="8,0,0,0" ToolTip="Browse logo file"/>
                        </Grid>
                        <TextBlock Style="{StaticResource Label}" Text="Printer device" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" x:Name="cbPrinterDevice" Style="{StaticResource DashCombo}"/>
                            <Button Grid.Column="1" x:Name="btnRefreshPrinters" Content="&#xE72C;"
                                    FontFamily="Segoe MDL2 Assets" FontSize="14"
                                    Click="BtnRefreshPrinters_Click" Style="{StaticResource DashBtn}"
                                    Background="{StaticResource InputBg}" Foreground="{StaticResource TextPrimary}"
                                    BorderBrush="{StaticResource InputStroke}" BorderThickness="1"
                                    Width="38" Padding="0" Margin="8,0,0,0" ToolTip="Refresh printer list"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== QUEUE BROWSER ===== -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" MinHeight="300" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header with search -->
                    <Grid Grid.Row="0" Margin="20,16,20,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource SectionTitle}" Text="Queue Browser" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" x:Name="txtSearch" Style="{StaticResource DashTextBox}"
                                 TextChanged="TxtSearch_TextChanged"
                                 Tag="Search name or QR code..." Height="34"/>
                        <Button Grid.Column="4" x:Name="btnFetchQueue" Content="Fetch Queue"
                                Click="BtnFetchQueue_Click" Style="{StaticResource DashBtn}"
                                Background="{StaticResource BlueBg}" Foreground="#FF0984E3"
                                BorderBrush="{StaticResource Blue}" BorderThickness="1"/>
                    </Grid>

                    <!-- Data grid -->
                    <DataGrid Grid.Row="1" x:Name="dgQueue"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Extended"
                              Background="Transparent"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#FFF0F0F0"
                              FontFamily="Segoe UI Variable Text, Segoe UI"
                              FontSize="12"
                              Margin="8,0,8,8"
                              MaxHeight="300">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40">
                                <DataGridCheckBoxColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <CheckBox x:Name="chkSelectAll" Click="ChkSelectAll_Click"/>
                                    </DataTemplate>
                                </DataGridCheckBoxColumn.HeaderTemplate>
                            </DataGridCheckBoxColumn>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="120"/>
                            <DataGridTextColumn Header="Surname" Binding="{Binding Surname}" Width="120"/>
                            <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="120"/>
                            <DataGridTextColumn Header="QR Data" Binding="{Binding QrData}" Width="150"/>
                            <DataGridTextColumn Header="Events" Binding="{Binding EventsDisplay}" Width="120"/>
                            <DataGridTextColumn Header="Printer" Binding="{Binding PrinterId}" Width="55"/>
                            <DataGridTextColumn Header="Printed" Binding="{Binding PrintedDisplay}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Bottom bar: count + print button -->
                    <Grid Grid.Row="2" Margin="20,8,20,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="txtQueueInfo" Style="{StaticResource Label}"
                                   Text="No data loaded" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" x:Name="btnPrintSelected" Content="Print Selected"
                                Click="BtnPrintSelected_Click" Style="{StaticResource DashBtn}"
                                Background="{StaticResource Accent}" Foreground="White"
                                BorderThickness="0" Width="130"/>
                        <Button Grid.Column="3" x:Name="btnSelectUnprinted" Content="Select Unprinted"
                                Click="BtnSelectUnprinted_Click" Style="{StaticResource DashBtn}"
                                Background="{StaticResource GreenBg}" Foreground="{StaticResource Green}"
                                BorderBrush="{StaticResource Green}" BorderThickness="1" Width="130"/>
                        <Button Grid.Column="5" x:Name="btnDeleteSelected" Content="Delete Selected"
                                Click="BtnDeleteSelected_Click" Style="{StaticResource DashBtn}"
                                Background="{StaticResource RedBg}" Foreground="{StaticResource Red}"
                                BorderBrush="{StaticResource Red}" BorderThickness="1" Width="130"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ===== ACTIVITY LOG ===== -->
            <Border Grid.Row="4" Style="{StaticResource Card}" Padding="0" MinHeight="280">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Log Header -->
                    <Grid Grid.Row="0" Margin="20,16,20,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource SectionTitle}" Text="Activity Log"/>
                        <Button Grid.Column="1" x:Name="btnClearLog" Content="Clear"
                                Click="BtnClearLog_Click" Style="{StaticResource DashBtn}"
                                Background="Transparent" Foreground="{StaticResource TextSecondary}"
                                BorderThickness="0" Height="28" FontSize="12"/>
                    </Grid>

                    <!-- Log List -->
                    <ListBox Grid.Row="1" x:Name="lstLog"
                             FontFamily="Cascadia Code, Consolas" FontSize="12"
                             Background="Transparent" Foreground="{StaticResource TextPrimary}"
                             BorderThickness="0" Margin="4,0,4,8"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="16,6"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="BorderBrush" Value="#FFF5F5F5"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFFAFAFA"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentBg}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Footer -->
            <TextBlock Grid.Row="6" Margin="0,12,0,0"
                       Text="Sticker Print Station v1.0  —  Each machine listens only for its assigned printer jobs"
                       Foreground="{StaticResource TextTertiary}" FontSize="11"
                       FontFamily="Segoe UI Variable Text, Segoe UI" HorizontalAlignment="Center"/>
        </Grid>
    </ScrollViewer>
</Window>
